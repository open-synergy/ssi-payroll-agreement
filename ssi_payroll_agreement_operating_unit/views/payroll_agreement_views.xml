<odoo>

<!-- SEARCH VIEW -->
<record id="payroll_agreement_view_search" model="ir.ui.view">
    <field name="name">payroll_agreement: Operating Unit Search</field>
    <field name="model">payroll_agreement</field>
    <field
            name="inherit_id"
            ref="ssi_payroll_agreement.payroll_agreement_view_search"
        />
    <field name="priority" eval="30" />
    <field name="arch" type="xml">
        <data>
            <xpath expr="//field[@name='company_id']" position="after">
                <field
                        name="operating_unit_id"
                        groups="operating_unit.group_multi_operating_unit"
                    />
            </xpath>
            <xpath expr="//filter[@name='grp_company']" position="after">
                <filter
                        name="grp_ou"
                        string="Operating Unit"
                        context="{'group_by':'operating_unit_id'}"
                        groups="operating_unit.group_multi_operating_unit"
                    />
            </xpath>
        </data>
    </field>
</record>

<!-- TREE VIEW -->
<record id="payroll_agreement_view_tree" model="ir.ui.view">
    <field name="name">payroll_agreement: Operating Unit Tree</field>
    <field name="model">payroll_agreement</field>
    <field name="inherit_id" ref="ssi_payroll_agreement.payroll_agreement_view_tree" />
    <field name="priority" eval="30" />
    <field name="arch" type="xml">
        <data>
            <xpath expr="//field[@name='company_id']" position="after">
                <field
                        name="operating_unit_id"
                        groups="operating_unit.group_multi_operating_unit"
                        optional="hide"
                    />
            </xpath>
        </data>
    </field>
</record>

<!-- FORM VIEW -->
<record id="payroll_agreement_view_form" model="ir.ui.view">
    <field name="name">payroll_agreement: Operating Unit Form</field>
    <field name="model">payroll_agreement</field>
    <field name="inherit_id" ref="ssi_payroll_agreement.payroll_agreement_view_form" />
    <field name="priority" eval="30" />
    <field name="arch" type="xml">
        <data>
            <xpath expr="//field[@name='company_id']" position="after">
                <field
                        name="operating_unit_id"
                        groups="operating_unit.group_multi_operating_unit"
                    />
            </xpath>
        </data>
    </field>
</record>

</odoo>
